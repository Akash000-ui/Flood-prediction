# Flask
FLASK_SECRET_KEY=replace-with-a-long-random-secret
DEBUG_MODE=false
API_HOST=0.0.0.0
# API_PORT is optional locally. Render provides PORT automatically.
API_PORT=5000

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Google Earth Engine
GEE_PROJECT=student-study-app-468414
# For cloud deployments, prefer service account auth:
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY=

# Email alerts
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_ALERT_THRESHOLD=0.5
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Flood Prediction System
DEFAULT_ALERT_EMAIL=

# Optional weather API mode
USE_WEATHER_API=false
WEATHER_API_KEY=
WEATHER_API_DAYS_BACK=7
